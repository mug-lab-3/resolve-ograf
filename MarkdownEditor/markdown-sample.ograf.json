{
  "$schema": "https://ograf.ebu.io/v1/specification/json-schemas/graphics/schema.json",
  "id": "io.github.mug.markdown-sample",
  "version": "1.0.0",
  "name": "Mug Markdown Text",
  "main": "markdown-sample.js",
  "supportsRealTime": false,
  "supportsNonRealTime": true,
  "renderRequirements": [
    {
      "accessToPublicInternet": {
        "ideal": false
      }
    }
  ],
  "schema": {
    "type": "object",
    "properties": {
      "markdownText": {
        "type": "string",
        "title": "Markdown Text",
        "gddType": "multi-line",
        "default": "# H1\n\n**Bold**  \n*italic*  \n~~Strikethrough~~  \n`inline code`\n\n> Blockquote\n\n---\n\n- Item1\n- Item2\n\n1. Number 1\n2. Number 2\n\n| Column 1 | Column 2 |\n| -------- | -------- |\n| Text 1   | Text 2   |\n"
      },
      "fontFamily": {
        "type": "string",
        "title": "Font Family",
        "default": "Arial"
      },
      "textColor": {
        "type": "string",
        "title": "Text Color",
        "gddType": "color-rrggbb",
        "default": "#ffffff"
      },
      "backgroundColor": {
        "type": "string",
        "title": "Background Color",
        "gddType": "color-rrggbbaa",
        "default": "#00000080"
      },
      "borderRadius": {
        "type": "number",
        "title": "Border Radius",
        "default": 0.02,
        "minimum": 0.0,
        "maximum": 1.0
      },
      "scaleAll": {
        "type": "number",
        "title": "Overall Scale",
        "default": 1.0,
        "minimum": 0.0,
        "maximum": 5.0
      },
      "fontScale": {
        "type": "number",
        "title": "Font Scale",
        "default": 1.0,
        "minimum": 0.0,
        "maximum": 5.0
      },
      "backgroundScaleX": {
        "type": "number",
        "title": "Background Scale X",
        "default": 1.0,
        "minimum": 0.0,
        "maximum": 5.0
      },
      "backgroundScaleY": {
        "type": "number",
        "title": "Background Scale Y",
        "default": 1.0,
        "minimum": 0.0,
        "maximum": 5.0
      }
    }
  }
}